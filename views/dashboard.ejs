<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RiskMonitor • Live Threat Dashboard</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  <%- include('partials/header.ejs') %>

    <div class="dashboard-content">
      <!-- Page Header -->
      <div class="page-header">
        <div>
          <h1>Threat Intelligence Dashboard</h1>
          <p style="color:#14b8a6; font-weight:500;">Real-time monitoring • 12 platforms connected</p>
        </div>
        <div style="display:flex; align-items:center; gap:12px; color:#14b8a6; font-size:0.95rem;">
          <i class="bi bi-clock"></i>
          Last updated: <span id="last-updated">just now</span>
        </div>
      </div>

      <!-- Stats Cards -->
      <div class="stats-grid">
        <div class="stat-card transactions">
          <div>
            <div class="label">Total Transactions</div>
            <div class="value">
              <%= totalTransactions.toLocaleString() %>
            </div>
          </div>
          <i class="bi bi-cart-check"></i>
        </div>

        <div class="stat-card fraud">
          <div>
            <div class="label">Fraud Detected</div>
            <div class="value" style="color:#ef4444">
              <%= fraudDetected.toLocaleString() %>
            </div>
          </div>
          <i class="bi bi-exclamation-triangle"></i>
        </div>

        <div class="stat-card risk">
          <div>
            <div class="label">Overall Risk Score</div>
            <div class="value">
              <%= riskScore %><span style="font-size:1.1rem;color:#aaa">/100</span>
            </div>
          </div>
          <i class="bi bi-speedometer2"></i>
        </div>

        <div class="stat-card detection">
          <div>
            <div class="label">Detection Rate</div>
            <div class="value" style="color:#10b981">
              <%= detectionRate %>%
            </div>
          </div>
          <i class="bi bi-shield-check"></i>
        </div>
      </div>

      <!-- Charts -->
      <div class="charts-row">
        <!-- Fraud Trend -->
        <div class="chart-card">
          <div class="chart-header">
            <h2>Fraud Trend • Last 7 Months</h2>
            <span style="color:#10b981;font-weight:600;display:flex;align-items:center;gap:6px;">
              <i class="bi bi-circle-fill" style="font-size:10px;animation:pulse 2s infinite;"></i> LIVE
            </span>
          </div>
          <canvas id="fraudTrendChart" height="130"></canvas>
        </div>

        <!-- Safe vs Fraud Pie -->
        <div class="chart-card">
          <div class="chart-header">
            <h2>Safe vs Fraudulent Transactions</h2>
          </div>
          <canvas id="safeFraudChart" height="300"></canvas>
        </div>
      </div>

      <!-- Recent Alerts -->
      <div class="table-card">
        <div class="table-header">
          <h2>Recent Security Alerts</h2>
          <button onclick="refreshDashboard()"
            style="background:#27272a;border:none;color:white;padding:12px 28px;border-radius:9999px;cursor:pointer;display:flex;align-items:center;gap:10px;font-weight:500;">
            <i class="bi bi-arrow-clockwise"></i> Refresh Data
          </button>
        </div>
        <table>
          <thead>
            <tr>
              <th>Transaction ID</th>
              <th>Fraud Type</th>
              <th>Amount</th>
              <th>Risk Level</th>
              <th>Time</th>
            </tr>
          </thead>
          <tbody>
            <% recentAlerts.forEach(alert=> { %>
              <tr>
                <td style="font-family:monospace;font-weight:500">
                  <%= alert.id %>
                </td>
                <td>
                  <%= alert.type %>
                </td>
                <td style="font-weight:500">
                  <%= alert.amount %>
                </td>
                <td>
                  <span
                    class="risk-badge <%= alert.risk === 'High' || alert.risk === 'Critical' ? 'risk-high' : alert.risk === 'Medium' ? 'risk-medium' : 'risk-low' %>">
                    <%= alert.risk %>
                  </span>
                </td>
                <td>
                  <%= alert.time %>
                </td>
              </tr>
              <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <%- include('partials/footer.ejs') %>

      <script>
        // Clean JSON data for charts
        const chartData = <%= JSON.stringify({
          months: months,
          fraudTrend: fraudTrend,
          safeCount: safeCount,
          fraudCount: fraudCount
        }) %>;

        function initCharts() {
          // Professional Area Line Chart
          new Chart(document.getElementById('fraudTrendChart'), {
            type: 'line',
            data: {
              labels: chartData.months,
              datasets: [{
                label: 'Fraud Incidents',
                data: chartData.fraudTrend,
                borderColor: '#14b8a6',
                backgroundColor: 'rgba(20, 184, 166, 0.15)',
                borderWidth: 4,
                tension: 0.35,
                pointRadius: 5,
                pointHoverRadius: 8,
                fill: true
              }]
            },
            options: {
              responsive: true,
              plugins: {
                legend: { display: false },
                tooltip: { backgroundColor: '#111', titleColor: '#fff', bodyColor: '#14b8a6' }
              },
              scales: {
                y: { grid: { color: '#27272a' }, ticks: { color: '#a3a3a8' } },
                x: { grid: { color: '#27272a' }, ticks: { color: '#a3a3a8' } }
              }
            }
          });

          // Premium Doughnut Chart
          new Chart(document.getElementById('safeFraudChart'), {
            type: 'doughnut',
            data: {
              labels: ['Safe Transactions', 'Fraudulent'],
              datasets: [{
                data: [chartData.safeCount, chartData.fraudCount],
                backgroundColor: ['#10b981', '#ef4444'],
                borderColor: '#161618',
                borderWidth: 8,
                hoverOffset: 15
              }]
            },
            options: {
              responsive: true,
              cutout: '72%',
              plugins: {
                legend: {
                  position: 'bottom',
                  labels: { color: '#ddd', padding: 30, font: { size: 15, weight: '500' } }
                }
              }
            }
          });
        }

        function refreshDashboard() {
          const btn = event.currentTarget;
          const original = btn.innerHTML;
          btn.innerHTML = `<i class="bi bi-arrow-clockwise" style="animation:spin 1s linear infinite"></i> Updating...`;
          setTimeout(() => {
            location.reload();
          }, 1100);
        }

        // Update timestamp
        function updateTimestamp() {
          const el = document.getElementById('last-updated');
          let seconds = 0;
          setInterval(() => {
            seconds++;
            el.textContent = seconds < 60 ? `${seconds} seconds ago` : 'just now';
          }, 10000);
        }

        window.onload = () => {
          initCharts();
          updateTimestamp();
        };
      </script>

      <script src="/js/main.js"></script>
</body>

</html>