<%- include('partials/header', { showNav: false, title: 'Login · RiskMonitor' }) %>

<div class="login-wrapper">
  <div class="login-left">
    <div class="login-brand">
      <span class="brand-icon-lg"><i class="bi bi-shield-exclamation"></i></span>
      <h1 class="brand-headline">RiskMonitor</h1>
      <p class="brand-sub">E-Commerce Threat Intelligence Platform</p>
    </div>
    <div class="login-stats">
      <div class="ls-item">
        <span class="ls-num">48K+</span>
        <span class="ls-label">Transactions Monitored</span>
      </div>
      <div class="ls-item">
        <span class="ls-num">1.2K</span>
        <span class="ls-label">Fraud Cases Detected</span>
      </div>
      <div class="ls-item">
        <span class="ls-num">99.4%</span>
        <span class="ls-label">Detection Accuracy</span>
      </div>
    </div>
  </div>

  <div class="login-right">
    <div class="login-card">
      <div class="login-card-header">
        <h2>Secure Access</h2>
        <p>Sign in to your monitoring dashboard</p>
      </div>

      <% if (error) { %>
        <div class="alert-error">
          <i class="bi bi-exclamation-triangle-fill"></i>
          <%= error %>
        </div>
      <% } %>

      <form action="/login" method="POST" class="login-form">
        <div class="form-group">
          <label for="email">Email Address</label>
          <div class="input-wrap">
            <i class="bi bi-envelope input-icon"></i>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="admin@riskmonitor.io"
              required
              autocomplete="email"
            />
          </div>
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <div class="input-wrap">
            <i class="bi bi-lock input-icon"></i>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="••••••••"
              required
              autocomplete="current-password"
            />
          </div>
        </div>

        <button type="submit" class="btn-login">
          <span>Access Dashboard</span>
          <i class="bi bi-arrow-right"></i>
        </button>
      </form>

      <p class="login-hint">
        <i class="bi bi-info-circle"></i>
        Demo: <code>admin@riskmonitor.io</code> / <code>secure123</code>
      </p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
